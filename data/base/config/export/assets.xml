<ModOps>

    <!-- Asset ModOp workaround: use it once before you use asset modops -->
    <ModOp Add="/AssetList/Groups[last()]">
        <Group>
            <Assets />
        </Group>
    </ModOp>

    <!--
    new style asset modop: use Type="Replace" or "Merge" and specify the path to the 
    Object you want to modify, then put the modified Object in the ModOp body, 
    you can modify any field of the Object this way, and you can also add 
    new fields if needed, just make sure the GUID of the Object is correct 
    and matches the one in the game data, otherwise it will create a new 
    Object instead of modifying the existing one

    <ModOp Type="Merge" GUID="5473" Path="Values/Object">
    <ModOp Merge="@5473/Object">

    <ModOp Type="Merge" GUID="5473" Path="Values/ShipModuleOwner/ShipModulesConfig">

    -->

	<!-- fancy icon -->
    <ModOp Merge="@5473/Standard">
        <IconFilename>data/ewjax/ui/fhd/base/icon_content/ship/fancy_flagship.png</IconFilename>
    </ModOp>

	<!-- 
	customize number of different modules
	note: the total number of modules (Archers + Scorpion + Catapult) 
	must be less than or equal to FOUR, and there is no	error checking.  
	-->
	<ModOp Merge="@5473/ShipModuleOwner/ShipModulesConfig">
		<ShipModulesConfig>
			<Archers>
				<MaximumModuleCount>4</MaximumModuleCount>
				<DefaultModuleCount>0</DefaultModuleCount>
			</Archers>
			<Scorpion>
				<MaximumModuleCount>4</MaximumModuleCount>
				<DefaultModuleCount>0</DefaultModuleCount>
			</Scorpion>
			<Catapult>
				<MaximumModuleCount>4</MaximumModuleCount>
				<DefaultModuleCount>0</DefaultModuleCount>
			</Catapult>
		</ShipModulesConfig>

    </ModOp>

    <ModOp Merge="@5473/ShipModuleOwner/ShipModulesConfig/Archers/DefaultModuleCount">
        <ModValue Insert="$num_flagship_archers" />
    </ModOp>

    <ModOp Merge="@5473/ShipModuleOwner/ShipModulesConfig/Scorpion/DefaultModuleCount">
        <ModValue Insert="$num_flagship_scorpions" />
    </ModOp>

    <ModOp Merge="@5473/ShipModuleOwner/ShipModulesConfig/Catapult/DefaultModuleCount">
        <ModValue Insert="$num_flagship_catapults" />
    </ModOp>

    <!-- reactivate the custom flagship skins -->
    <ModOp Merge="@5473/Object">
        <Object>
			<Skins>
				<SkinList>
					<Item>
						<SkinAssetGuid>90967</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>90968</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>91039</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>91040</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>122164</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>119864</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>119868</SkinAssetGuid>
					</Item>
					<Item>
						<SkinAssetGuid>119869</SkinAssetGuid>
					</Item>
				</SkinList>
			</Skins>
			<AssignDefaultProfile>1</AssignDefaultProfile>
			<IgnoreForMinimapGeneration>1</IgnoreForMinimapGeneration>
        </Object>
    </ModOp>

</ModOps>


